# ---- Database (Vercel Postgres / Neon / Supabase) ----
# Use the POOLED connection string for serverless.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
# Set to "false" only for a local non-SSL Postgres.
DATABASE_SSL=true
# Single firm = single tenant. Any UUID; keep it stable.
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ---- Anthropic (AI drafting) ----
ANTHROPIC_API_KEY=sk-ant-...
# Bump to the current Sonnet model string when newer ones ship.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- Microsoft Graph (Outlook sending + reply polling) ----
# From your Azure AD app registration (application permissions: Mail.Send, Mail.Read).
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# The dedicated mailbox these run as, e.g. outreach@yourfirm-capital.com
OUTLOOK_MAILBOX=outreach@yourfirm-capital.com

# ---- App access ----
# Shared access key the UI asks for. Leave blank in local dev to disable the gate.
APP_PASSWORD=choose-a-strong-key
# Protects the cron endpoint. Vercel auto-sends this as a Bearer token to crons.
CRON_SECRET=another-strong-key

# ---- Automation tuning ----
# Days after sending with no reply before a prospect is flagged "Follow up".
FOLLOWUP_DAYS=5
